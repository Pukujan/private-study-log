{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cortex.local/schemas/assurance/execution-contract.schema.json",
  "title": "Cortex execution contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "contract_id", "task_id", "profile", "runtime_mode",
    "driver", "required_phases", "required_tools", "enabled_tools",
    "research_policy", "mission_policy", "fallback_behavior",
    "evidence_requirements", "telemetry_policy"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "contract_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "profile": {"type": "string", "minLength": 1},
    "runtime_mode": {"enum": ["governed", "advisory", "ungoverned"]},
    "driver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "runtime_version", "model_id", "wrapper_version"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "runtime_version": {"type": "string", "minLength": 1},
        "model_id": {"type": "string", "minLength": 1},
        "wrapper_version": {"type": "string", "minLength": 1}
      }
    },
    "required_phases": {"$ref": "#/$defs/nonEmptyStrings"},
    "required_tools": {"$ref": "#/$defs/nonEmptyStrings"},
    "enabled_tools": {"$ref": "#/$defs/nonEmptyStrings"},
    "research_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "evidence_types"],
      "properties": {
        "required": {"type": "boolean"},
        "evidence_types": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "mission_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "claims_disjoint", "merge_receipt_required"],
      "properties": {
        "required": {"type": "boolean"},
        "claims_disjoint": {"type": "boolean"},
        "merge_receipt_required": {"type": "boolean"}
      }
    },
    "fallback_behavior": {"enum": ["fail_closed", "mark_ungoverned", "allow_advisory"]},
    "evidence_requirements": {"$ref": "#/$defs/nonEmptyStrings"},
    "telemetry_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "sinks", "correlation_field", "missing_evidence_result"],
      "properties": {
        "required": {"type": "boolean"},
        "sinks": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "correlation_field": {"type": "string", "minLength": 1},
        "missing_evidence_result": {"enum": ["FAIL", "UNRESOLVED", "ENVIRONMENT_UNAVAILABLE"]}
      }
    }
  },
  "$defs": {
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
